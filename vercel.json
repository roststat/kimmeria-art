{
  "rewrites": [
    { "source": "/api/auth/callback", "destination": "/api/auth/callback" },
    { "source": "/api/auth", "destination": "/api/auth/index" },
    { "source": "/api/schedules", "destination": "/api/schedules" },
    { "source": "/admin/schedule", "destination": "/admin/schedule/index.html" },
    { "source": "/privacy", "destination": "/privacy/index.html" },
    { "source": "/terms", "destination": "/terms/index.html" },
    { "source": "/cookies", "destination": "/cookies/index.html" },
    { "source": "/kurs-mikrodram", "destination": "/kurs-mikrodram/index.html" },
    { "source": "/spasibo", "destination": "/spasibo/index.html" }
  ],
  "headers": [
    {
      "source": "/events.json",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Cache-Control", "value": "public, max-age=300" }
      ]
    },
    {
      "source": "/widget.js",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Cache-Control", "value": "public, max-age=300" }
      ]
    }
  ]
}
